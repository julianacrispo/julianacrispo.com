---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import type { Article, WithContext } from "schema-dts";

// SSR: resolve the entry at request time instead of prerendering every page
// via getStaticPaths(), so build time stays flat as pages grow. Sitemap slugs
// are wired in via src/lib/sitemap/get-sitemap-paths.ts.
const { slug } = Astro.params;
const entry = slug ? await getEntry("pages", slug) : undefined;

if (!entry || (import.meta.env.PROD && entry.data.draft)) {
  return new Response(null, { status: 404 });
}

const { Content } = await render(entry);
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : undefined;
const articleJsonLd: WithContext<Article> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  name: entry.data.title,
  ...(entry.data.description && { description: entry.data.description }),
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: entry.data.pubDate.toISOString(),
  ...(canonicalUrl && {
    url: canonicalUrl,
    mainEntityOfPage: canonicalUrl,
  }),
};
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  jsonLd={articleJsonLd}
>
  <article class="prose mx-auto max-w-3xl px-4 py-12">
    <Content />
  </article>
</Layout>
